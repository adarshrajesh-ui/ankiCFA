# CFA exam-prep AI configuration — copy to `.env` (which is gitignored).
# Every AI feature works fully with AI OFF: if OPENAI_API_KEY is absent, the
# LLM client returns {ok: False} and callers use their deterministic fallback.

# Required to turn AI ON. Never commit a real key.
OPENAI_API_KEY=sk-your-key-here

# Optional: override the model (default: gpt-4o-mini).
# CFA_LLM_MODEL=gpt-4o-mini

# Optional: per-process safety caps. The client refuses further calls once
# either cap is reached (returns {ok: False, error: "cost_cap_exceeded"}).
# CFA_LLM_MAX_TOKENS_PER_PROCESS=200000
# CFA_LLM_MAX_COST_USD=1.00

# Optional: transient-error retries with exponential backoff (default: 2).
# CFA_LLM_MAX_RETRIES=2
